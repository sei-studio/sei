{
  "name": "sei",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main/index.js",
  "bin": {
    "sei": "src/bot/cli/index.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "sei": "node src/bot/cli/index.js",
    "verify:phase2": "node scripts/verify-phase2.js",
    "verify:phase3": "node scripts/verify-phase3.js",
    "verify:phase9-skin-server": "node scripts/verify-skinServer.mjs",
    "verify:phase9-mojang": "tsx scripts/verify-mojangSkinLookup.mjs",
    "verify:phase9-installs": "node --import ./scripts/lib/electron-stub-loader.mjs scripts/verify-phase9-installs.mjs",
    "verify:phase9-csl-config": "node --import ./scripts/lib/electron-stub-loader.mjs scripts/verify-phase9-csl-config.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "mineflayer": "^4.23.0",
    "mineflayer-auto-eat": "^5.0.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "skinview3d": "3.4.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@electron/notarize": "3.1.1",
    "@electron/rebuild": "4.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "42.0.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "tsx": "^4.22.1",
    "typescript": "^5.4.0",
    "vite": "^7.0.0"
  }
}
