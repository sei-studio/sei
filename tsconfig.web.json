{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["src/renderer/src/*"],
      "@shared/*": ["src/shared/*"]
    },
    "baseUrl": ".",
    // Typecheck only. electron-vite (esbuild/rollup) builds the renderer from
    // source; without this `tsc --build` emits sibling .js next to every .tsx,
    // which the Vite dev server then serves stale in place of live edits (and
    // broke a running dev session on 260707). tsconfig.node.json redirects its
    // emit to dist/ instead; the renderer has no such output, so it must noEmit.
    "noEmit": true
  },
  "include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx", "src/shared/**/*.ts"]
}
