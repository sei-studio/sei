# tsc --build emit artifacts under src/ (we never ship .js next to .ts;
# bundlers consume the .ts directly). Generated by `npx tsc --build` runs
# against tsconfig.web.json which does not set noEmit.
src/**/*.js
*.tsbuildinfo

