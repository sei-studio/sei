config.json
config.example.json

# local env vars (Apple signing credentials etc.)
.env
.env.*
!.env.example
# dev-only secrets (e.g. Anthropic test key) — defense-in-depth; the real key
# lives OUTSIDE the repo at ~/.sei-dev/anthropic-test-key and is never committed.
.sei-dev/
*anthropic-test-key*
*.secret
node_modules/
mineflayer/
.claude/
test/
logs/

# user-specific memory — generated during onboarding / at runtime
memory/OWNER.md
memory/DIARY.md
memory/AFFECT.md

# Electron build outputs
dist/
release/
out/
*.log
.DS_Store

# dev scratch / local backups (never commit)
.bg-shell/
*.bak

# tsc --build emit artifacts under src/ (we never ship .js next to .ts;
# bundlers consume the .ts directly). Generated by `npx tsc --build` runs
# against tsconfig.web.json which does not set noEmit.
src/**/*.js
# EXCEPT src/bot — the utilityProcess bot is hand-written JavaScript (NOT a tsc
# shadow), so it must be tracked. Without this exemption a fresh `git init`
# silently drops the entire bot and the build fails to resolve ../bot/* imports.
!src/bot/**
*.tsbuildinfo

# Prompt-verification harness — not for source control
scripts/verify-prompts.mjs

# Internal architecture notes — not for public README
ARCHITECTURE.md

# (the proxy server + supabase/ backend moved to the private sei-proxy repo)

